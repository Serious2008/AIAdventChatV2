## Model pattern:
```swift
struct MyModel: Identifiable, Codable {
    let id: UUID
    let name: String

    init(name: String) {
        self.id = UUID()
        self.name = name
    }
}
```

## Strict rules — NEVER violate:
- NEVER force unwrap: no `!` after optionals. Use `guard let` or `if let`
- NEVER hardcode API keys — use `settings.apiKey`
- NEVER block main thread — use `async/await` or background DispatchQueue
- NEVER use `Any` type — use concrete types
- NEVER write UI code inside ViewModels
- NEVER access UserDefaults directly — use Settings class

## Error handling — ALWAYS:
```swift
// BAD:
let url = URL(string: str)!

// GOOD:
guard let url = URL(string: str) else {
    print("❌ Invalid URL")
    return
}

// BAD:
let data = try! decoder.decode(...)

// GOOD:
do {
    let data = try decoder.decode(...)
} catch {
    print("❌ Decode error: \(error)")
}
```

## Async pattern:
```swift
// PREFER async/await:
func fetchData() async throws -> Data {
    let (data, _) = try await URLSession.shared.data(from: url)
    return data
}

// For completion handlers:
func fetchData(completion: @escaping (Result<Data, Error>) -> Void) {
    URLSession.shared.dataTask(with: url) { data, _, error in
        DispatchQueue.main.async {
            if let error { completion(.failure(error)); return }
            guard let data else { return }
            completion(.success(data))
        }
    }.resume()
}
```

